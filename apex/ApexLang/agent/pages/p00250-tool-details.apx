page 250 (
    name: Tool Details
    alias: TOOL-DETAILS
    title: Tool Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region tool-details (
        name: Tool Details
        type: form
        source {
            location: localDatabase
            tableName: AI_TOOLS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P250_AI_TOOL_ID (
        type: hidden
        layout {
            sequence: 10
            region: @tool-details
            slot: regionBody
        }
        source {
            formRegion: @tool-details
            column: AI_TOOL_ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P250_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: right
        }
        layout {
            sequence: 30
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @tool-details
            column: DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P250_FUNCTION_NAME (
        type: textField
        label {
            label: Function Name
            alignment: right
        }
        layout {
            sequence: 50
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @tool-details
            column: FUNCTION_NAME
            dataType: varchar2
        }
    )

    pageItem P250_IDENTIFIER (
        type: textField
        label {
            label: Identifier
            alignment: right
        }
        layout {
            sequence: 40
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 30
        }
        source {
            formRegion: @tool-details
            column: IDENTIFIER
            dataType: varchar2
        }
    )

    pageItem P250_NAME (
        type: textField
        label {
            label: Name
            alignment: right
        }
        layout {
            sequence: 20
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @tool-details
            column: NAME
            dataType: varchar2
        }
    )

    pageItem P250_PARAMETERS (
        type: textarea
        label {
            label: Parameters
            alignment: left
        }
        layout {
            sequence: 60
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 8
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @tool-details
            column: PARAMETERS
            dataType: clob
        }
        sessionState {
            dataType: clob
        }
    )

    pageItem P250_PARAMETERS_REQUIRED (
        type: textarea
        label {
            label: Parameters Required
            alignment: right
        }
        layout {
            sequence: 70
            region: @tool-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            formRegion: @tool-details
            column: PARAMETERS_REQUIRED
            dataType: varchar2
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P250_AI_TOOL_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P250_AI_TOOL_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P250_AI_TOOL_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 11630513752428729
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-tool-details (
        name: Initialize form Tool Details
        type: formInitialization
        formRegion: @tool-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 11629712339428728
        }
    )

    process process-form-tool-details (
        name: Process form Tool Details
        type: formAutoRowProcessing
        formRegion: @tool-details
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 11630138867428729
        }
    )

)

