page 1 (
    name: Home
    alias: HOME
    title: Agent
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region yaaa-yet-another-ai-agent (
        name: YAAA (Yet another AI Agent)
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/hero
            templateOptions: #DEFAULT#
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
    )

)

