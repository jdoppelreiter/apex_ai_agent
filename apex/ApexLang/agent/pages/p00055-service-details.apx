page 55 (
    name: Service Details
    alias: SERVICE-DETAILS
    title: Service Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region authentication (
        name: Authentication
        type: staticContent
        source {
            htmlCode: Choose an pre-defined Apex Web-Credential (Workspace Setting)
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
            ]
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region service-details (
        name: Service Details
        type: form
        source {
            location: localDatabase
            tableName: AI_SERVICES
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P55_AI_SERVICE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @service-details
            slot: regionBody
        }
        source {
            formRegion: @service-details
            column: AI_SERVICE_ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P55_APEX_WS_CRED_STATIC_ID (
        type: selectList
        label {
            label: Web-Credential
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery: select name d, static_id r from apex_workspace_credentials
            nullDisplayValue: No Authentication
        }
        layout {
            sequence: 10
            region: @authentication
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @service-details
            column: APEX_WS_CRED_STATIC_ID
            dataType: varchar2
        }
    )

    pageItem P55_BASE_URL (
        type: textField
        label {
            label: Base Url
            alignment: left
        }
        layout {
            sequence: 50
            region: @service-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @service-details
            column: BASE_URL
            dataType: varchar2
        }
    )

    pageItem P55_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 40
            region: @service-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @service-details
            column: DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P55_IDENTIFIER (
        type: textField
        label {
            label: Identifier
            alignment: left
        }
        layout {
            sequence: 30
            region: @service-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 30
        }
        source {
            formRegion: @service-details
            column: IDENTIFIER
            dataType: varchar2
        }
    )

    pageItem P55_MODEL (
        type: textField
        label {
            label: Model
            alignment: left
        }
        layout {
            sequence: 60
            region: @service-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 200
        }
        source {
            formRegion: @service-details
            column: MODEL
            dataType: varchar2
        }
    )

    pageItem P55_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        layout {
            sequence: 20
            region: @service-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @service-details
            column: NAME
            dataType: varchar2
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P55_AI_SERVICE_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P55_AI_SERVICE_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P55_AI_SERVICE_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 3376689084860128
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-service-details (
        name: Initialize form Service Details
        type: formInitialization
        formRegion: @service-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 3375879257860128
        }
    )

    process process-form-service-details (
        name: Process form Service Details
        type: formAutoRowProcessing
        formRegion: @service-details
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 3376270230860128
        }
    )

)

