customAttribute ADD_TO_ACTIONS (
    apexlangName: addToActionsClassname
    attribute: 11
    name: Add To Actions - Classname
    scope: report
    appearance {
        attributeGroup: @generalSettings
        sequence: 110
    }
    help {
        helpText:
            ```
            Specify the class-name for buttons to be attached to the Floating Action Buttons. 
            If left empty the default value is: "fab-add-to-actions"
            Classname can be added to Apex-buttons in "Appearance" -> "CSS Classes"
            ```
    }
)

