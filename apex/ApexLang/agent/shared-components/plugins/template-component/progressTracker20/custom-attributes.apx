    appearance {
        sequence: 100
    }
)

customAttribute RENDER (
    apexlangName: render
    attribute: 18
    name: Render
    scope: report
    appearance {
        sequence: 180
    }
)

customAttribute SHOW_ALL_URL (
    apexlangName: showAllUrl
    attribute: 8
    name: Show All Url
    scope: report
    type: sessionStateValue
    appearance {
        sequence: 80
    }
)

customAttribute STATE (
    apexlangName: state
    attribute: 11
    name: State
    scope: report
    type: sessionStateValue
    appearance {
        sequence: 110
    }
)

customAttribute STATUS_MESSAGE (
